#!/bin/sh

set -e

python_renamer(){
    # Rename python2.* / python3.* (the real interpreter) to python*-real so
    # the launcher can be installed at the canonical name.
    find /opt/python/bin -type f -executable -name 'python[23].*' \
         -not -name '*-real' -not -name '*-config' | while read -r line; do
        echo "Renaming $line"
        mv "$line" "$(echo "$line" | sed -r 's/python([23])\.(.*)$/python\1.\2-real/')" \
            || (echo "Failed to rename $line" && exit 1)
    done

    # Echo the result
    find /opt/python/bin -type f -executable -name '*-real' | while read -r line; do
        echo "New name: $line"
    done
}

pip_renamer() {
    # Rename pip2.* / pip3.* (the real pip script) to pip*-real so the
    # launcher can be installed at the canonical name.
    find /opt/python/bin -type f -executable -name 'pip[23].*' \
         -not -name '*-real' | while read -r line; do
        echo "Renaming $line"
        mv "$line" "$(echo "$line" | sed -r 's/pip([23])\.(.*)$/pip\1.\2-real/')" \
            || (echo "Failed to rename $line" && exit 1)
    done

    # Echo the result
    find /opt/python/bin -type f -executable -name '*-real' | while read -r line; do
        echo "New name: $line"
    done
}

shared_libraries_mover() {
    # Move /opt/shared_libraries to /opt/python/shared_libraries
    mv /opt/shared_libraries /opt/python/shared_libraries
}

sysconfig_path_rewriter() {
    # `make install` bakes build-time LDFLAGS (including
    # `-L/opt/shared_libraries/lib -lffi -Wl,-rpath,/opt/shared_libraries/lib`
    # from build_python.sh) into files under /opt/python/lib:
    #   * `_sysconfigdata*.py`     read by sysconfig / distutils
    #   * `config-*/Makefile` or `config/Makefile`
    #                              read by python-config.sh, some setup.py
    #   * `python-config.py`       emits LDFLAGS on stdout
    # shared_libraries_mover just relocated the directory, so those baked
    # strings now point at a nonexistent path. rpath-patcher.sh fixes ELF
    # RPATH for runtime lookup, but downstream `pip install` that compiles
    # C extensions (e.g. psutil on x86 where no manylinux_i686 wheel exists)
    # reads sysconfig's LDFLAGS and feeds `-L/opt/shared_libraries/lib` to
    # ld, which fails with "cannot find -lffi" because -L is gone.
    #
    # For py3 we keep the install fully relocatable — the launcher already
    # makes ELF lookup $ORIGIN-relative, so a user who moves /opt/python to
    # /tmp/mypack/python should be able to `pip install foo-from-source` and
    # have ld find our shipped libs. We therefore rewrite the absolute
    # prefix to a sentinel `@STANDALONE_PYTHON_PREFIX@/shared_libraries` and
    # let standalone_python_musl.py's .pth hook substitute `sys.prefix` for
    # the sentinel at runtime, before any caller reads sysconfig.
    #
    # Both py2 and py3 use the same sentinel: their respective .pth hooks
    # (standalone_python_musl_py2.py, standalone_python_musl.py) expand
    # @STANDALONE_PYTHON_PREFIX@ to the live sys.prefix at interpreter
    # startup. This keeps installs fully relocatable (move /opt/python →
    # /tmp/whatever and `pip install foo-from-source` still resolves libs
    # inside the moved tree) without any ELF rewriting at move time.
    find /opt/python/lib \
         -type f \
         \( -name '_sysconfigdata*.py' \
            -o -name 'Makefile' \
            -o -name 'python-config.py' \) \
         -exec grep -l '/opt/shared_libraries' {} + 2>/dev/null \
         | while read -r f; do
             sed -i 's|/opt/shared_libraries|@STANDALONE_PYTHON_PREFIX@/shared_libraries|g' "$f"
             echo "Rewrote sysconfig paths (sentinel) in $f"
         done

    # Also patch the `python*-config` shell script if it bakes the absolute
    # path (py2's config/Makefile-based python-config does; py3's
    # python3.N-config is a shim that re-execs the interpreter). Restrict
    # to shebanged text files so we never sed a real binary — the new
    # token is 22 bytes longer than the old and would corrupt fixed-size
    # structures if one of the real interpreter ELFs happened to contain
    # the literal path by accident.
    for f in /opt/python/bin/*; do
        [ -f "$f" ] || continue
        head_bytes=$(head -c 2 "$f" 2>/dev/null || true)
        [ "$head_bytes" = "#!" ] || continue
        grep -q '/opt/shared_libraries' "$f" 2>/dev/null || continue
        sed -i 's|/opt/shared_libraries|@STANDALONE_PYTHON_PREFIX@/shared_libraries|g' "$f"
        echo "Rewrote sysconfig paths (sentinel) in $f"
    done

    # Invalidate .pyc caches for any _sysconfigdata*.py we changed — stale
    # .pyc would mask the .py edit until the next full compileall.
    find /opt/python/lib \
         \( -path '*/__pycache__/_sysconfigdata*' \
            -o -name '_sysconfigdata.pyc' \
            -o -name '_sysconfigdata.pyo' \) \
         -delete 2>/dev/null || true
}

shebang_rewriter() {
    # `make install` drops helper scripts into /opt/python/bin (idle3.12,
    # 2to3-3.12, python3.12-config, pydoc3.12, pip3.12, etc.) with shebangs
    # pointing at the original python binary (e.g. /opt/python/bin/python3.12).
    # python_renamer just moved that binary to *-real, so those shebangs now
    # dangle. Retarget every shebang in /opt/python/bin that points at the
    # old python/pip paths to the launcher path that a later build step
    # installs (/opt/python/bin/python<major>). The launcher dispatches on
    # argv[0] basename, so running these scripts through it behaves as
    # python-mode invocation (argv[1] = script).
    #
    # The major version is whichever python*-real this build produced, so
    # the same logic works for both the Python 2 and Python 3 layouts.
    target_python=""
    for f in /opt/python/bin/python*-real; do
        case "$(basename "$f")" in
            python2.*) target_python="/opt/python/bin/python2" ;;
            python3.*) target_python="/opt/python/bin/python3" ;;
        esac
    done
    if [ -z "$target_python" ]; then
        echo "shebang_rewriter: no python*-real found, skipping"
        return
    fi

    for f in /opt/python/bin/*; do
        [ -f "$f" ] || continue
        # Only text scripts have `#!` as the first two bytes; skip ELFs.
        head_bytes=$(head -c 2 "$f" 2>/dev/null || true)
        [ "$head_bytes" = "#!" ] || continue
        first_line=$(head -n 1 "$f")
        case "$first_line" in
            '#!/opt/python/bin/python'*|'#!/opt/python/bin/pip'*)
                # Replace just the interpreter path (everything up to the
                # first whitespace). Trailing flags like ` -E` are preserved.
                sed -i "1 s|^#![^[:space:]]*|#!${target_python}|" "$f"
                echo "Rewrote shebang: $f -> #!${target_python}"
                ;;
        esac
    done
}

main() {
    python_renamer
    pip_renamer
    shebang_rewriter
    shared_libraries_mover
    sysconfig_path_rewriter
}

main

#!/bin/sh

set -e

python_renamer(){
    # Rename python2.* / python3.* (the real interpreter) to python*-real so
    # the launcher can be installed at the canonical name.
    find /opt/python/bin -type f -executable -name 'python[23].*' \
         -not -name '*-real' -not -name '*-config' | while read -r line; do
        echo "Renaming $line"
        mv "$line" "$(echo "$line" | sed -r 's/python([23])\.(.*)$/python\1.\2-real/')" \
            || (echo "Failed to rename $line" && exit 1)
    done

    # Echo the result
    find /opt/python/bin -type f -executable -name '*-real' | while read -r line; do
        echo "New name: $line"
    done
}

pip_renamer() {
    # Rename pip2.* / pip3.* (the real pip script) to pip*-real so the
    # launcher can be installed at the canonical name.
    find /opt/python/bin -type f -executable -name 'pip[23].*' \
         -not -name '*-real' | while read -r line; do
        echo "Renaming $line"
        mv "$line" "$(echo "$line" | sed -r 's/pip([23])\.(.*)$/pip\1.\2-real/')" \
            || (echo "Failed to rename $line" && exit 1)
    done

    # Echo the result
    find /opt/python/bin -type f -executable -name '*-real' | while read -r line; do
        echo "New name: $line"
    done
}

shared_libraries_mover() {
    # Move /opt/shared_libraries to /opt/python/shared_libraries
    mv /opt/shared_libraries /opt/python/shared_libraries
}

shebang_rewriter() {
    # `make install` drops helper scripts into /opt/python/bin (idle3.12,
    # 2to3-3.12, python3.12-config, pydoc3.12, pip3.12, etc.) with shebangs
    # pointing at the original python binary (e.g. /opt/python/bin/python3.12).
    # python_renamer just moved that binary to *-real, so those shebangs now
    # dangle. Retarget every shebang in /opt/python/bin that points at the
    # old python/pip paths to the launcher path that a later build step
    # installs (/opt/python/bin/python<major>). The launcher dispatches on
    # argv[0] basename, so running these scripts through it behaves as
    # python-mode invocation (argv[1] = script).
    #
    # The major version is whichever python*-real this build produced, so
    # the same logic works for both the Python 2 and Python 3 layouts.
    target_python=""
    for f in /opt/python/bin/python*-real; do
        case "$(basename "$f")" in
            python2.*) target_python="/opt/python/bin/python2" ;;
            python3.*) target_python="/opt/python/bin/python3" ;;
        esac
    done
    if [ -z "$target_python" ]; then
        echo "shebang_rewriter: no python*-real found, skipping"
        return
    fi

    for f in /opt/python/bin/*; do
        [ -f "$f" ] || continue
        # Only text scripts have `#!` as the first two bytes; skip ELFs.
        head_bytes=$(head -c 2 "$f" 2>/dev/null || true)
        [ "$head_bytes" = "#!" ] || continue
        first_line=$(head -n 1 "$f")
        case "$first_line" in
            '#!/opt/python/bin/python'*|'#!/opt/python/bin/pip'*)
                # Replace just the interpreter path (everything up to the
                # first whitespace). Trailing flags like ` -E` are preserved.
                sed -i "1 s|^#![^[:space:]]*|#!${target_python}|" "$f"
                echo "Rewrote shebang: $f -> #!${target_python}"
                ;;
        esac
    done
}

main() {
    python_renamer
    pip_renamer
    shebang_rewriter
    shared_libraries_mover
}

main
